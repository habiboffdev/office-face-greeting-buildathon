{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "admin",
      "description": "User role \u2014 new users start as admin for 2-day trial"
    },
    "trial_expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the 2-day admin trial expires"
    }
  }
}