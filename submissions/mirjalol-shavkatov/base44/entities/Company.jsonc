{
  "name": "Company",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Company display name"
    },
    "owner_email": {
      "type": "string",
      "description": "Email of the admin who created the company"
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "create": {},
    "read": {},
    "update": {},
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}